# Get this from your PostgreSQL provider dashboard.
# Example providers: Neon https://console.neon.tech, Supabase https://supabase.com/dashboard, Railway https://railway.app/dashboard
DATABASE_URL=

# Generate a strong random secret for Better Auth.
# Docs: https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=

# Get Stripe keys from the Stripe Dashboard.
# API keys: https://dashboard.stripe.com/apikeys
# Webhook signing secret: https://dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
VITE_STRIPE_PUBLISHABLE_KEY=

# Local development URL. Change this to your deployed app URL in production.
VITE_BASE_URL=http://localhost:3000

# Get Cloudinary values from the Cloudinary Console.
# Cloud name: https://console.cloudinary.com/settings/account
# Upload preset: https://console.cloudinary.com/settings/upload
VITE_CLOUDINARY_CLOUD_NAME=
VITE_CLOUDINARY_UPLOAD_PRESET=
