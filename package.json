{
  "name": "ogkify",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev --port 3000",
    "dev:clean": "pnpm clean && vite dev --port 3000 --force",
    "build": "vite build",
    "start": "node --env-file=.env .output/server/index.mjs",
    "serve": "vite preview",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier",
    "check": "prettier --write . && eslint --fix",
    "clean": "rm -rf node_modules/.vite .tanstack-start/build",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.1.1",
    "@neondatabase/serverless": "^1.0.1",
    "@tailwindcss/vite": "^4.1.11",
    "@tanstack/react-query": "^5.81.5",
    "@tanstack/react-router": "^1.125.0",
    "@tanstack/react-router-with-query": "^1.125.0",
    "@tanstack/react-start": "^1.126.1",
    "@tanstack/router-plugin": "^1.125.0",
    "@uploadthing/react": "^7.3.2",
    "better-auth": "^1.2.12",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.0.0",
    "drizzle-orm": "^0.44.2",
    "lucide-react": "^0.525.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "radix-ui": "^1.4.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-dropzone": "^14.3.8",
    "react-hook-form": "^7.59.0",
    "react-icons": "^5.5.0",
    "recharts": "^3.0.2",
    "sonner": "^2.0.5",
    "stripe": "^18.2.1",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4.1.11",
    "tailwindcss-animate": "^1.0.7",
    "tw-animate-css": "^1.3.4",
    "uploadthing": "^7.7.3",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.2.0",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "babel-plugin-react-compiler": "19.1.0-rc.2",
    "drizzle-kit": "^0.31.4",
    "prettier": "^3.6.2",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vite": "7.0.0",
    "vitest": "^3.2.4"
  }
