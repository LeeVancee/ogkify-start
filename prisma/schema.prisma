generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                    String    @id
  accountId             String    @map("account_id") @db.VarChar
  providerId            String    @map("provider_id") @db.VarChar
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at") @db.Timestamp(6)
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at") @db.Timestamp(6)
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt             DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  user                  user      @relation(fields: [userId], references: [id])

  @@map("account")
}

model session {
  id             String   @id
  expiresAt      DateTime @map("expires_at") @db.Timestamp(6)
  token          String   @db.VarChar
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  ipAddress      String?  @map("ip_address") @db.VarChar
  userAgent      String?  @map("user_agent")
  userId         String   @map("user_id")
  impersonatedBy String?  @map("impersonated_by") @db.VarChar
  user           user     @relation(fields: [userId], references: [id])

  @@map("session")
}

model user {
  id            String    @id
  name          String    @db.VarChar
  email         String    @db.VarChar
  emailVerified Boolean   @map("email_verified")
  image         String?
  role          String?   @db.VarChar
  banned        Boolean?
  banReason     String?   @map("ban_reason")
  banExpires    DateTime? @map("ban_expires") @db.Timestamp(6)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  accounts      account[]
  carts         cart[]
  orders        order[]
  sessions      session[]

  @@map("user")
}

model verification {
  id         String    @id
  identifier String    @db.VarChar
  value      String    @db.VarChar
  expiresAt  DateTime  @map("expires_at") @db.Timestamp(6)
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt  DateTime? @default(now()) @map("updated_at") @db.Timestamp(6)

  @@map("verification")
}

model cartItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cartId    String   @map("cart_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int      @default(1)
  colorId   String?  @map("color_id") @db.Uuid
  sizeId    String?  @map("size_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  cart      cart     @relation(fields: [cartId], references: [id])
  color     color?   @relation(fields: [colorId], references: [id])
  product   product  @relation(fields: [productId], references: [id])
  size      size?    @relation(fields: [sizeId], references: [id])

  @@map("cart_items")
}

model cart {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id")
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime   @default(now()) @map("updated_at") @db.Timestamp(6)
  items     cartItem[]
  user      user       @relation(fields: [userId], references: [id])

  @@map("carts")
}

model category {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar
  imageUrl  String?   @map("image_url")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime  @default(now()) @map("updated_at") @db.Timestamp(6)
  products  product[]

  @@map("categories")
}

model color {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @db.VarChar
  value           String           @db.VarChar
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @map("updated_at") @db.Timestamp(6)
  cartItems       cartItem[]
  orderItems      orderItem[]
  productToColors productToColor[]

  @@map("colors")
}

model image {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  productId String   @map("product_id") @db.Uuid
  url       String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  product   product  @relation(fields: [productId], references: [id])

  @@map("images")
}

model orderItem {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  productId String   @map("product_id") @db.Uuid
  quantity  Int
  price     Float
  colorId   String?  @map("color_id") @db.Uuid
  sizeId    String?  @map("size_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamp(6)
  color     color?   @relation(fields: [colorId], references: [id])
  order     order    @relation(fields: [orderId], references: [id])
  product   product  @relation(fields: [productId], references: [id])
  size      size?    @relation(fields: [sizeId], references: [id])

  @@map("order_items")
}

model order {
  id              String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orderNumber     String        @map("order_number") @db.VarChar
  userId          String        @map("user_id")
  status          orderStatus   @default(PENDING)
  totalAmount     Float         @map("total_amount")
  phone           String?       @db.VarChar
  shippingAddress String?       @map("shipping_address")
  paymentMethod   String?       @map("payment_method") @db.VarChar
  paymentIntent   String?       @map("payment_intent") @db.VarChar
  paymentStatus   paymentStatus @default(UNPAID) @map("payment_status")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime      @default(now()) @map("updated_at") @db.Timestamp(6)
  items           orderItem[]
  user            user          @relation(fields: [userId], references: [id])

  @@map("orders")
}

model product {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String           @db.VarChar
  description     String
  price           Float
  isFeatured      Boolean          @default(false) @map("is_featured")
  isArchived      Boolean          @default(false) @map("is_archived")
  categoryId      String           @map("category_id") @db.Uuid
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime         @default(now()) @map("updated_at") @db.Timestamp(6)
  cartItems       cartItem[]
  images          image[]
  orderItems      orderItem[]
  category        category         @relation(fields: [categoryId], references: [id])
  productToColors productToColor[]
  productToSizes  productToSize[]

  @@map("products")
}

model productToColor {
  productId String  @map("product_id") @db.Uuid
  colorId   String  @map("color_id") @db.Uuid
  color     color   @relation(fields: [colorId], references: [id])
  product   product @relation(fields: [productId], references: [id])

  @@id([productId, colorId])
  @@map("products_to_colors")
}

model productToSize {
  productId String  @map("product_id") @db.Uuid
  sizeId    String  @map("size_id") @db.Uuid
  product   product @relation(fields: [productId], references: [id])
  size      size    @relation(fields: [sizeId], references: [id])

  @@id([productId, sizeId])
  @@map("products_to_sizes")
}

model size {
  id             String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String          @db.VarChar
  value          String          @db.VarChar
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime        @default(now()) @map("updated_at") @db.Timestamp(6)
  cartItems      cartItem[]
  orderItems     orderItem[]
  productToSizes productToSize[]

  @@map("sizes")
}

enum orderStatus {
  PENDING
  PAID
  COMPLETED
  CANCELLED

  @@map("order_status")
}

enum paymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED

  @@map("payment_status")
}
