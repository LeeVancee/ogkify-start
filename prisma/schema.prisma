generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model account {
  id                       String    @id
  account_id               String    @db.VarChar
  provider_id              String    @db.VarChar
  user_id                  String
  access_token             String?
  refresh_token            String?
  id_token                 String?
  access_token_expires_at  DateTime? @db.Timestamp(6)
  refresh_token_expires_at DateTime? @db.Timestamp(6)
  scope                    String?
  password                 String?
  created_at               DateTime  @default(now()) @db.Timestamp(6)
  updated_at               DateTime  @default(now()) @db.Timestamp(6)
  user                     user      @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "account_user_id_user_id_fk")
}

model session {
  id              String   @id
  expires_at      DateTime @db.Timestamp(6)
  token           String   @db.VarChar
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @default(now()) @db.Timestamp(6)
  ip_address      String?  @db.VarChar
  user_agent      String?
  user_id         String
  impersonated_by String?  @db.VarChar
  user            user     @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "session_user_id_user_id_fk")
}

model user {
  id             String    @id
  name           String    @db.VarChar
  email          String    @db.VarChar
  email_verified Boolean
  image          String?
  role           String?   @db.VarChar
  banned         Boolean?
  ban_reason     String?
  ban_expires    DateTime? @db.Timestamp(6)
  created_at     DateTime  @default(now()) @db.Timestamp(6)
  updated_at     DateTime  @default(now()) @db.Timestamp(6)
  account        account[]
  carts          carts[]
  orders         orders[]
  session        session[]
}

model verification {
  id         String    @id
  identifier String    @db.VarChar
  value      String    @db.VarChar
  expires_at DateTime  @db.Timestamp(6)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  updated_at DateTime? @default(now()) @db.Timestamp(6)
}

model cart_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cart_id    String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int      @default(1)
  color_id   String?  @db.Uuid
  size_id    String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  carts      carts    @relation(fields: [cart_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "cart_items_cart_id_carts_id_fk")
  colors     colors?  @relation(fields: [color_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cart_items_color_id_colors_id_fk")
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cart_items_product_id_products_id_fk")
  sizes      sizes?   @relation(fields: [size_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "cart_items_size_id_sizes_id_fk")
}

model carts {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id    String
  created_at DateTime     @default(now()) @db.Timestamp(6)
  updated_at DateTime     @default(now()) @db.Timestamp(6)
  cart_items cart_items[]
  user       user         @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "carts_user_id_user_id_fk")
}

model categories {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name       String     @db.VarChar
  image_url  String?
  created_at DateTime   @default(now()) @db.Timestamp(6)
  updated_at DateTime   @default(now()) @db.Timestamp(6)
  products   products[]
}

model colors {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar
  value              String               @db.VarChar
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @default(now()) @db.Timestamp(6)
  cart_items         cart_items[]
  order_items        order_items[]
  products_to_colors products_to_colors[]
}

model images {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  product_id String   @db.Uuid
  url        String
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "images_product_id_products_id_fk")
}

model order_items {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_id   String   @db.Uuid
  product_id String   @db.Uuid
  quantity   Int
  price      Float
  color_id   String?  @db.Uuid
  size_id    String?  @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  colors     colors?  @relation(fields: [color_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_color_id_colors_id_fk")
  orders     orders   @relation(fields: [order_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_order_id_orders_id_fk")
  products   products @relation(fields: [product_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_product_id_products_id_fk")
  sizes      sizes?   @relation(fields: [size_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "order_items_size_id_sizes_id_fk")
}

model orders {
  id               String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  order_number     String         @db.VarChar
  user_id          String
  status           order_status   @default(PENDING)
  total_amount     Float
  phone            String?        @db.VarChar
  shipping_address String?
  payment_method   String?        @db.VarChar
  payment_intent   String?        @db.VarChar
  payment_status   payment_status @default(UNPAID)
  created_at       DateTime       @default(now()) @db.Timestamp(6)
  updated_at       DateTime       @default(now()) @db.Timestamp(6)
  order_items      order_items[]
  user             user           @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "orders_user_id_user_id_fk")
}

model products {
  id                 String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String               @db.VarChar
  description        String
  price              Float
  is_featured        Boolean              @default(false)
  is_archived        Boolean              @default(false)
  category_id        String               @db.Uuid
  created_at         DateTime             @default(now()) @db.Timestamp(6)
  updated_at         DateTime             @default(now()) @db.Timestamp(6)
  cart_items         cart_items[]
  images             images[]
  order_items        order_items[]
  categories         categories           @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "products_category_id_categories_id_fk")
  products_to_colors products_to_colors[]
  products_to_sizes  products_to_sizes[]
}

model products_to_colors {
  product_id String   @db.Uuid
  color_id   String   @db.Uuid
  colors     colors   @relation(fields: [color_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_to_colors_color_id_colors_id_fk")
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_to_colors_product_id_products_id_fk")

  @@id([product_id, color_id])
}

model products_to_sizes {
  product_id String   @db.Uuid
  size_id    String   @db.Uuid
  products   products @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_to_sizes_product_id_products_id_fk")
  sizes      sizes    @relation(fields: [size_id], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "products_to_sizes_size_id_sizes_id_fk")

  @@id([product_id, size_id])
}

model sizes {
  id                String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name              String              @db.VarChar
  value             String              @db.VarChar
  created_at        DateTime            @default(now()) @db.Timestamp(6)
  updated_at        DateTime            @default(now()) @db.Timestamp(6)
  cart_items        cart_items[]
  order_items       order_items[]
  products_to_sizes products_to_sizes[]
}

enum order_status {
  PENDING
  PAID
  COMPLETED
  CANCELLED
}

enum payment_status {
  UNPAID
  PAID
  REFUNDED
  FAILED
}
